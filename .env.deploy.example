# Optional root-level deploy overrides.
# Copy to .env.deploy.uat.local or .env.deploy.production.local.
# The .local files are ignored by git.

# Shared VPS target
DEPLOY_HOST=13.140.189.236
DEPLOY_USER=root
DEPLOY_PORT=22

# Image moderation service
AIP_INTERNAL_API_KEY=
AIP_ENABLE_MODERATION_WORKER=true
AIP_EXPOSE_PLAYGROUND_UI=auto

# Collage service
COLLAGE_SERVICE_API_KEY=

# Shared app/service database and storage.
# Usually these are already present in tfpphotographers/.env.<target>.local.
DATABASE_URL=
TFP_DATABASE_URL=
B2_ENDPOINT=
B2_ACCESS_KEY_ID=
B2_SECRET_ACCESS_KEY=
B2_BUCKET_NAME=
B2_REGION=us-east-005
